# Copy this file to .env and fill in the values from your Supabase project.
# Settings -> API in the Supabase dashboard.

# --- Required to run the app locally ---

# Supabase project URL and public anon key (used by the browser + server actions)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Secret guarding the /api/revalidate endpoint (any random string)
REVALIDATE_SECRET=some-long-random-string

# --- Optional ---
# The full set of Supabase/Postgres variables exported by Vercel is also
# supported but NOT required for local development. The app only reads the
# three variables above. You can leave the rest out if you like.
# SUPABASE_SERVICE_ROLE_KEY=
# POSTGRES_URL=
