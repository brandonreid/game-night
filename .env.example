# Copy this file to .env and fill in the values from your Turso database.
# Create one with the Turso CLI: `turso db create game-night`, then grab the
# URL with `turso db show --url game-night` and a token with
# `turso db tokens create game-night`.

# --- Required to run the app ---

# Turso / libSQL connection (used by server actions)
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Secret guarding the /api/revalidate endpoint (any random string)
REVALIDATE_SECRET=some-long-random-string

# --- Local development tip ---
# Instead of a hosted Turso db you can point at a plain SQLite file. No auth
# token is needed in that case:
# TURSO_DATABASE_URL=file:local.db
